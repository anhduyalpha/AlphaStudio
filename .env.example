# AlphaStudio local backend
PORT=8787
HOST=127.0.0.1
CORS_ORIGIN=http://localhost:5173
# Production serves the built frontend and API from one origin by default.
SERVE_FRONTEND=1
# Required before using a non-loopback HOST. Use the same value as
# VITE_API_TOKEN at frontend build time when hosting for other devices.
# API_AUTH_TOKEN=replace-with-a-long-random-token
# VITE_API_TOKEN=replace-with-the-same-token
# Optional frontend API base for a separately hosted frontend.
# VITE_API_URL=http://127.0.0.1:8787
DATA_DIR=./data
DB_PATH=./data/alphastudio.db
MAX_UPLOAD_BYTES=104857600
MAX_OUTPUT_BYTES=209715200
# Reject archive bombs before they can fill data/temp.
MAX_ARCHIVE_ENTRIES=10000
MAX_EXTRACTED_BYTES=209715200
# Optional Unicode font for text/Markdown-to-PDF on minimal Linux images.
# PDF_FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
# Dedicated process-worker pool. Leave these commented for adaptive CPU/RAM
# sizing. On a 4–8 GiB machine, uncomment all values and use 1.
# WORKER_POOL_SIZE=1
# IMAGE_WORKER_CONCURRENCY=1
# PDF_WORKER_CONCURRENCY=1
# MEDIA_WORKER_CONCURRENCY=1
# OFFICE_WORKER_CONCURRENCY=1
# GENERAL_WORKER_CONCURRENCY=1
MAX_JOB_ATTEMPTS=2
WORKER_HEARTBEAT_MS=2000
WORKER_STALE_MS=12000
WORKER_CANCEL_GRACE_MS=2000
JOB_TIMEOUT_MS=300000
# Optional Python conversion runtime (opt-in via `npm run python:install`).
# Bridge subprocess timeout and best-effort address-space cap (POSIX only).
PYTHON_TIMEOUT_MS=300000
PYTHON_MAX_MEMORY_MB=1024
TEMP_TTL_MS=3600000
WORKSPACE_RETENTION_MS=604800000
# Keep downloaded/extracted tool staging only for installer debugging.
# ALPHA_KEEP_TOOL_DOWNLOADS=0
# Pandoc is unused by the 3.6 runtime and remains optional.
# ALPHA_REQUIRE_PANDOC=0
LOG_LEVEL=info
